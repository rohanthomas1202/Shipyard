# Railway environment template for rebuilt Ship app
# Values are defaults/placeholders -- Railway provisions actual secrets

# Node.js
NODE_ENV=production
PORT=3000

# Database (Railway Postgres addon sets this automatically)
DATABASE_URL=postgresql://placeholder:placeholder@localhost:5432/ship

# Auth / Sessions
JWT_SECRET=CHANGE_ME_IN_RAILWAY
SESSION_SECRET=CHANGE_ME_IN_RAILWAY

# App
APP_URL=https://RAILWAY_DOMAIN_HERE
LOG_LEVEL=info

# Build
NPM_CONFIG_PRODUCTION=false
